{
  "name": "recurring-free-slots",
  "version": "0.1.0",
  "description": "Compute a day's free time slots from recurring weekly busy blocks, handling overnight-wrapping blocks (sleep, night shifts) and overlaps correctly.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "scheduling",
    "availability",
    "free-busy",
    "calendar",
    "time-slots",
    "recurring",
    "overnight",
    "booking",
    "calendly"
  ],
  "license": "MIT",
  "author": "Bhumik Khatwani",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhumik154/recurring-free-slots.git"
  },
  "bugs": {
    "url": "https://github.com/bhumik154/recurring-free-slots/issues"
  },
  "homepage": "https://github.com/bhumik154/recurring-free-slots#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
